# 使用 Python 3.9 瘦身版作為基礎
FROM python:3.9-slim

# 安裝系統依賴：ffmpeg (音訊處理) 與 MuseScore (樂譜渲染)
RUN apt-get update && apt-get install -y \
    ffmpeg \
    musescore3 \
    xvfb \
    && rm -rf /var/lib/apt/lists/*

# 設定工作目錄
WORKDIR /app

# 複製你的 n8n 處理腳本或 Python API 程式碼
COPY . .

# 安裝 Python 必備庫 (music21 用於處理樂譜邏輯)
RUN pip install --no-cache-dir music21 basicpitch flask

# MuseScore 在 Linux 執行需要虛擬顯示器 (xvfb)
ENV QT_QPA_PLATFORM=offscreen

# 啟動你的 API 服務
CMD ["python", "main.py"]
